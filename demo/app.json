{
    "name": "ai-demo",
    "description": "Symfony AI Demo Application",
    "keywords": [
        "php",
        "symfony"
    ],
    "repository": "https://github.com/tacman/ai",
    "scripts": {
        "dokku": {
            "predeploy": "bin/console asset-map:compile",
            "postdeploy": "bin/console about"
        }
    },
    "env": {
        "WEB_CONCURRENCY": {
            "description": "The number of PHP-FPM/nginx workers to run.",
            "value": "2"
        }
    },
    "image": "gliderlabs/herokuish",
    "buildpacks": [
        {
            "url": "https://github.com/heroku/heroku-buildpack-php.git"
        }
    ]
}
